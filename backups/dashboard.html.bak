<!DOCTYPE html>
<html lang="pt-PT">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboards e Analítica — Controlo Financeiro</title>
  <meta name="description" content="Dashboard financeiro com evolução patrimonial, burn rate semanal, radar de saúde financeira e tabela analítica mensal.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <div class="app-shell">
    <nav class="top-nav">
      <a class="nav-link" href="index.html">Registos</a>
      <a class="nav-link active" href="dashboard.html">Dashboards</a>
      <a class="nav-link" href="configuracao.html">Configuração</a>
    </nav>

    <header class="hero compact-hero">
      <div>
        <p class="eyebrow">Business Intelligence</p>
        <h1>Centro de Análise Financeira</h1>
        <p class="hero-copy">
          Dashboard dinâmico com evolução patrimonial e métricas de saúde financeira. Usa o seletor de mês para ver relatórios históricos.
        </p>
        <!-- Seletor de mês para relatório -->
        <div class="period-selector" id="dashboardMonthNav" role="group" aria-label="Navegação de mês">
          <button class="period-btn" id="dashPrevMonth" title="Mês anterior">‹ Anterior</button>
          <span class="period-btn active" id="dashboardMonthDisplay" style="cursor: default; pointer-events: none;">A carregar...</span>
          <button class="period-btn" id="dashNextMonth" title="Mês seguinte">Seguinte ›</button>
          <button class="period-btn" id="dashCurrentMonth" title="Voltar ao mês atual">Hoje</button>
        </div>
      </div>
      <div class="hero-card accent strong-card">
        <p>Património Líquido Global</p>
        <strong id="globalNetWorthDisplay">A calcular...</strong>
      </div>
      <div class="hero-card" style="background: var(--bg-color); color: var(--text-main); border: 2px solid var(--primary);">
        <p>Taxa de Poupança (Mês)</p>
        <strong id="savingsRateDisplay" style="color: var(--primary);">A calcular...</strong>
      </div>
    </header>

    <main class="dashboard-layout">
      <div class="dashboard-col">
        <section class="panel">
          <div class="panel-heading compact-heading">
            <h2>Evolução Patrimonial</h2>
            <p>Evolução da soma de todas as contas ao longo do tempo, com e sem recebíveis em aberto.</p>
          </div>
          <div style="position: relative; height:30vh; width:100%">
            <canvas id="longTermNetWorthChart"></canvas>
          </div>
        </section>

        <section class="panel">
          <div class="panel-heading compact-heading">
            <h2>Burn-Rate vs Orçamento Ideal</h2>
            <p>Calcula ao rubro se o que gastas em despesas + transferências está dentro da tua meta diária.</p>
          </div>
          <div style="position: relative; height:30vh; width:100%">
            <canvas id="weeklyBurnChart"></canvas>
          </div>
        </section>
      </div>

      <div class="dashboard-col">
        <section class="panel">
          <div class="panel-heading compact-heading">
            <h2>Distribuição por Categoria</h2>
            <p>Sombra do ciclo selecionado. Quais os setores a furar a margem?</p>
          </div>
          <div style="position: relative; height:40vh; width:100%; display: flex; justify-content: center;">
            <canvas id="categoryDistributionChart"></canvas>
          </div>
        </section>

        <section class="panel">
          <div class="panel-heading compact-heading">
            <h2>Top 5 Despesas Variáveis do Mês</h2>
            <p>Maiores custos diretos responsáveis pela erosão do ciclo corrente, ordenados de forma descendente.</p>
          </div>
          <div id="topExpensesList" class="item-list empty-state">
            A recrutar dados...
          </div>
        </section>
      </div>

      <!-- Radar de Saúde Financeira -->
      <section class="panel config-panel">
        <div class="panel-heading compact-heading">
          <h2>⚡ Radar de Saúde Financeira</h2>
          <p>Indicadores de consultoria em tempo real. O teu relatório estratégico automático.</p>
        </div>
        <div class="radar-grid">
          <div class="radar-card" id="runwayCard">
            <div class="radar-icon">🛡️</div>
            <div class="radar-content">
              <span class="radar-label">Autonomia Financeira</span>
              <strong class="radar-value" id="runwayDisplay">A calcular...</strong>
              <p class="radar-hint" id="runwayHint">Quantos meses sobrevives sem rendimento</p>
            </div>
            <div class="radar-badge" id="runwayBadge">—</div>
          </div>

          <div class="radar-card" id="emergencyFundCard">
            <div class="radar-icon">🏦</div>
            <div class="radar-content">
              <span class="radar-label">Fundo de Emergência (Meta: 6 meses)</span>
              <strong class="radar-value" id="emergencyFundDisplay">A calcular...</strong>
              <div class="progress-bar-track">
                <div class="progress-bar-fill" id="emergencyFundBar" style="width: 0%"></div>
              </div>
              <p class="radar-hint" id="emergencyFundHint">Progresso em direção à segurança total</p>
            </div>
          </div>

          <div class="radar-card" id="velocityCard">
            <div class="radar-icon">🎯</div>
            <div class="radar-content">
              <span class="radar-label">Aproveitamento do Orçamento</span>
              <strong class="radar-value" id="budgetVelocityDisplay">A calcular...</strong>
              <div class="progress-bar-track">
                <div class="progress-bar-fill" id="budgetVelocityBar" style="width: 0%"></div>
              </div>
              <p class="radar-hint" id="velocityHint">Percentagem do orçamento mensal já utilizada</p>
            </div>
          </div>

          <div class="radar-card" id="leakageAlertCard">
            <div class="radar-icon">🔍</div>
            <div class="radar-content">
              <span class="radar-label">Auditoria de Fluxo</span>
              <strong class="radar-value" id="leakageDisplay">A analisar...</strong>
              <p class="radar-hint" id="leakageHint">Diferença entre o saldo real e as despesas registadas</p>
            </div>
            <div class="radar-badge" id="leakageBadge">—</div>
          </div>
        </div>
      </section>

      <!-- Tabela Analítica Mensal -->
      <section class="panel config-panel">
        <div class="panel-heading compact-heading">
          <h2>Balanço Mensal Categórico</h2>
          <p>Tabela com o histórico completo — todos os meses com dados, ordenados cronologicamente.</p>
        </div>
        <div class="table-wrapper">
          <table class="analytic-table">
            <thead>
              <tr>
                <th>Mês de Referência</th>
                <th class="text-right">Ganhos Extra</th>
                <th class="text-right">Custo Fixo</th>
                <th class="text-right">Gasto Variável</th>
                <th class="text-right">Transf. / Poupanças</th>
                <th class="text-right">Saldo (Estimado)</th>
              </tr>
            </thead>
            <tbody id="globalAnalyticTable">
              <tr>
                <td colspan="6" style="text-align: center; font-style: italic; color: var(--text-muted);">A recrutar dados...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

    </main>
  </div>

  <template id="item-template">
    <article class="item-card">
      <div>
        <strong class="item-title"></strong>
        <p class="item-subtitle"></p>
      </div>
      <div class="item-actions">
        <span class="item-value"></span>
        <button type="button" class="ghost-btn">Remover</button>
      </div>
    </article>
  </template>

  <script src="script.js"></script>
  <script src="charts.js"></script>
  <script>
    // ── Navegação de mês no Dashboard ────────────────────────────
    (function() {
      function getMonthParts(key) {
        const [y, m] = key.split('-').map(Number);
        return { year: y, month: m };
      }
      function formatMonthKey(y, m) {
        return `${y}-${String(m).padStart(2, '0')}`;
      }
      function monthLabel(key) {
        const { year, month } = getMonthParts(key);
        return new Intl.DateTimeFormat('pt-PT', { month: 'long', year: 'numeric' })
          .format(new Date(year, month - 1, 1));
      }

      const display = document.getElementById('dashboardMonthDisplay');
      const prevBtn = document.getElementById('dashPrevMonth');
      const nextBtn = document.getElementById('dashNextMonth');
      const todayBtn = document.getElementById('dashCurrentMonth');

      let currentKey = typeof getMonthKey === 'function' ? getMonthKey() : '';
      const todayKey = currentKey;

      function updateDisplay() {
        if (display) display.textContent = monthLabel(currentKey);
        // Expor para charts.js
        window.dashboardMonthKey = currentKey;
        // Re-renderizar gráficos e radar
        if (typeof renderRadar === 'function') renderRadar();
        if (typeof renderTopExpenses === 'function') renderTopExpenses();
        if (typeof drawCategoryChart === 'function') {
          // Destruir e recriar o gráfico de categoria
          const canvas = document.getElementById('categoryDistributionChart');
          if (canvas && canvas._chartInstance) { canvas._chartInstance.destroy(); }
          drawCategoryChart();
        }
        if (typeof drawBurnRateChart === 'function') {
          const canvas = document.getElementById('weeklyBurnChart');
          if (canvas && canvas._chartInstance) { canvas._chartInstance.destroy(); }
          drawBurnRateChart();
        }
        if (typeof renderAnalyticTable === 'function') renderAnalyticTable();
        // Savings Rate
        if (typeof calculateSavingsRate === 'function') {
          const el = document.getElementById('savingsRateDisplay');
          if (el) el.textContent = calculateSavingsRate().toFixed(1) + '%';
        }
      }

      if (prevBtn) prevBtn.addEventListener('click', () => {
        const { year, month } = getMonthParts(currentKey);
        const newM = month === 1 ? 12 : month - 1;
        const newY = month === 1 ? year - 1 : year;
        currentKey = formatMonthKey(newY, newM);
        // Expor para o motor
        if (typeof state !== 'undefined') state.analysisMonth = currentKey;
        updateDisplay();
      });

      if (nextBtn) nextBtn.addEventListener('click', () => {
        const { year, month } = getMonthParts(currentKey);
        const newM = month === 12 ? 1 : month + 1;
        const newY = month === 12 ? year + 1 : year;
        currentKey = formatMonthKey(newY, newM);
        if (typeof state !== 'undefined') state.analysisMonth = currentKey;
        updateDisplay();
      });

      if (todayBtn) todayBtn.addEventListener('click', () => {
        currentKey = todayKey;
        if (typeof state !== 'undefined') state.analysisMonth = '';
        updateDisplay();
      });

      // Inicializar display
      if (display) display.textContent = monthLabel(currentKey);
      window.dashboardMonthKey = currentKey;
    })();
  </script>
</body>
</html>
